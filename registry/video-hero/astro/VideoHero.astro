---
interface Props {
  hero: {
    headline: string;
    logoUrl: string;
    videoUrl: string;
  };
  shopHref?: string;
}

const { hero, shopHref = "/shop" } = Astro.props;
const { headline, logoUrl, videoUrl } = hero;

const logoSrc =
  typeof logoUrl === "string" &&
  (logoUrl.startsWith("/") || /^[a-zA-Z][a-zA-Z\d+\-.]*:\/\//.test(logoUrl))
    ? logoUrl
    : "/images/showroom-logo.png";
---

<section class="relative h-screen w-full overflow-hidden bg-black">
  {videoUrl && (
    <video
      id="hero-video"
      class="absolute inset-0 h-full w-full object-cover"
      autoplay
      loop
      muted
      playsinline
      preload="metadata"
    >
      <source src={videoUrl} type="video/mp4" />
    </video>
  )}

  <div class="absolute inset-0 bg-[rgba(166,124,82,0.4)] pointer-events-none mix-blend-multiply"></div>

  <div class="absolute bottom-28 left-4 md:bottom-12 md:left-12 z-10">
    <a
      href={shopHref}
      class="font-commuters uppercase tracking-widest text-sm sm:text-base md:text-2xl lg:text-4xl text-[#fcf5e9] hover:opacity-80 transition-opacity"
    >
      Shop
    </a>
  </div>

  <div class="absolute bottom-28 right-4 md:bottom-12 md:right-12 z-10">
    <div class="flex items-center gap-2 md:gap-3">
      <div class="font-commuters whitespace-nowrap uppercase tracking-widest text-sm sm:text-base md:text-2xl lg:text-4xl text-[#fcf5e9]">
        {headline}
      </div>
      <img
        src={logoSrc}
        alt={headline}
        class="w-12 h-12 sm:w-16 sm:h-16 md:w-20 md:h-20 object-contain"
      />
    </div>
  </div>

  <div class="absolute left-0 top-0 bottom-0 w-1 bg-white/20 hidden md:block">
    <div class="absolute top-1/2 left-0 w-full h-24 bg-white/40 animate-pulse"></div>
  </div>
</section>

<script>
  const video = document.getElementById("hero-video") as HTMLVideoElement | null;
  if (video) {
    video.play().catch(() => {});
  }
</script>
